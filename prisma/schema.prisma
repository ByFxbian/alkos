generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  providerAccountId String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                     String               @id @default(cuid())
  email                  String               @unique
  name                   String?
  role                   Role                 @default(KUNDE)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  instagram              String?
  password               String?
  emailVerified          DateTime?
  completedAppointments  Int                  @default(0)
  hasFreeAppointment     Boolean              @default(false)
  bio                    String?
  image                  String?
  isBlocked              Boolean              @default(false)
  accounts               Account[]
  appointmentsAsBarber   Appointment[]        @relation("BarberAppointments")
  appointmentsAsCustomer Appointment[]        @relation("CustomerAppointments")
  availabilities         Availability[]
  barberShifts           BarberShift[]
  blockedTimes           BlockedTime[]        @relation("BarberBlockedTimes")
  passwordResetTokens    PasswordResetToken[]
  sessions               Session[]
  userLocations          UserLocation[]
}

model BlockedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Availability {
  id         String    @id @default(cuid())
  dayOfWeek  Int
  startTime  String
  endTime    String
  barberId   String?
  locationId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
  barber     User?     @relation(fields: [barberId], references: [id])
  location   Location? @relation(fields: [locationId], references: [id])

  @@index([barberId, dayOfWeek])
  @@index([locationId])
}

model BarberShift {
  id         String   @id @default(cuid())
  barberId   String
  locationId String
  date       DateTime @db.Date
  startTime  String
  endTime    String
  note       String?
  createdAt  DateTime @default(now())
  barber     User     @relation(fields: [barberId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])

  @@unique([barberId, date])
  @@index([barberId, date])
}

model Service {
  id           String        @id @default(cuid())
  name         String
  duration     Int
  price        Float
  createdAt    DateTime      @default(now())
  locationId   String?
  updatedAt    DateTime      @default(now()) @updatedAt
  appointments Appointment[]
  location     Location?     @relation(fields: [locationId], references: [id])
}

model Appointment {
  id                String      @id @default(cuid())
  startTime         DateTime
  endTime           DateTime
  createdAt         DateTime    @default(now())
  customerId        String
  serviceId         String
  barberId          String
  isFree            Boolean     @default(false)
  reminderSentAt    DateTime?
  reviewEmailSentAt DateTime?
  locationId        String?
  updatedAt         DateTime    @default(now()) @updatedAt
  walkInName        String?
  barber            User        @relation("BarberAppointments", fields: [barberId], references: [id])
  customer          User        @relation("CustomerAppointments", fields: [customerId], references: [id])
  location          Location?   @relation(fields: [locationId], references: [id])
  service           Service     @relation(fields: [serviceId], references: [id])
  stampToken        StampToken?

  @@index([barberId, startTime])
  @@index([customerId, startTime])
}

model StampToken {
  id            String      @id @default(cuid())
  token         String      @unique
  appointmentId String      @unique
  expiresAt     DateTime
  redeemedAt    DateTime?
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  token      String    @unique
  userId     String
  expiresAt  DateTime
  redeemedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BlockedTime {
  id        String   @id @default(cuid())
  startTime DateTime
  endTime   DateTime
  reason    String?
  barberId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  barber    User     @relation("BarberBlockedTimes", fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId, startTime, endTime])
}

model Location {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  address       String
  city          String
  postalCode    String
  phone         String?
  email         String?
  googleMapsUrl String?
  heroImage     String?
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
  galleryImages String[]
  appointments    Appointment[]
  availabilities  Availability[]
  barberShifts    BarberShift[]
  services        Service[]
  teamMembers     TeamMember[]  @relation("TeamMemberLocations")
  userLocations   UserLocation[]
}

model UserLocation {
  id         String   @id @default(cuid())
  userId     String
  locationId String
  isBookable Boolean  @default(true)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
  @@index([locationId])
}

model TeamMember {
  id        String     @id @default(cuid())
  name      String
  role      String
  bio       String?
  image     String?
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt
  locations Location[] @relation("TeamMemberLocations")
}

model Settings {
  id        String   @id
  key       String   @unique
  value     String
  updatedAt DateTime @default(now())
}

enum Role {
  KUNDE
  HEADOFBARBER
  BARBER
  ADMIN
}
